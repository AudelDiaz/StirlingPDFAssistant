# Telegram Bot Credentials
TELEGRAM_BOT_TOKEN="your_bot_token_here"

# Stirling PDF API Endpoint
# Example: http://192.168.10.148:25380/pdf-editor/
STIRLING_PDF_URL="http://your_stirling_ip:port/pdf-editor/"
STIRLING_PDF_API_KEY="your_api_key_here"

# Bot Security
# Your numerical Telegram User ID (get it from @userinfobot)
BOT_OWNER_ID="12345678"

# Optional relative path to users list JSON
USERS_FILE="users.json"

# Resource Safeguards
# Maximum number of concurrent tasks (default: 2)
MAX_CONCURRENT_TASKS=2

# Maximum file size allowed for upload in MB (default: 20)
MAX_FILE_SIZE_MB=20
