# Telegram Bot Credentials
TELEGRAM_BOT_TOKEN="your_bot_token_here"

# Stirling PDF API Endpoint
# Example: http://your-server-ip:port/pdf-editor/
STIRLING_PDF_URL="http://your_stirling_ip:port/pdf-editor/"
STIRLING_PDF_API_KEY="your_api_key_here"

# Bot Security
# Your numerical Telegram User ID (get it from @userinfobot)
BOT_OWNER_ID="12345678"

# Optional relative path to users list JSON
USERS_FILE="users.json"

# Resource Safeguards
# Maximum number of concurrent tasks (default: 2)
MAX_CONCURRENT_TASKS="2"

# Maximum file size allowed for upload in MB (default: 50)
MAX_FILE_SIZE_MB="50"

# API request timeout in seconds (default: 180)
# Increase this if LibreOffice conversions (.doc, .ppt, etc.) time out
API_TIMEOUT="180"

# --- Local Telegram Bot API Server ---
# To bypass Telegram's 20 MB file download limit, run a local Bot API server:
#   https://core.telegram.org/bots/api#using-a-local-bot-api-server
# Get TELEGRAM_API_ID and TELEGRAM_API_HASH from https://my.telegram.org
# Then uncomment and set the URL below (or use the telegram-bot-api Docker service):
# TELEGRAM_BOT_API_URL="http://telegram-bot-api:8081"
#
# TELEGRAM_LOCAL=true enables --local mode on the Bot API server so it
# connects directly to Telegram's datacenter (managed file IDs).
# Required when using a local Bot API server:
# TELEGRAM_API_ID="your_api_id"
# TELEGRAM_API_HASH="your_api_hash"
# Set this in the telegram-bot-api service environment (or via env_file):
# TELEGRAM_LOCAL=true
